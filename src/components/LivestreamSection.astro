---
// Static Twitch embed section
---

<section id="livestream" class="bg-[#0d1117] py-12 px-4 border-t border-gray-800">
  <div class="container mx-auto max-w-6xl">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 mb-6 px-2">
      <div class="text-left">
        <h2 class="text-2xl font-bold text-white flex items-center gap-3">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
          </span>
          We Are Live 24/7
        </h2>
        <p class="text-gray-400 text-sm mt-1">Tune in anytime to see what the community is building.</p>
      </div>
      <a
        href="https://twitch.tv/MakerDeck"
        target="_blank"
        class="text-purple-400 hover:text-white font-medium transition flex items-center gap-2"
      >
        Open in Twitch <i class="fa-solid fa-arrow-up-right-from-square"></i>
      </a>
    </div>

    <div class="bg-[#161b22] rounded-2xl p-2 md:p-4 ring-1 ring-white/10 shadow-2xl">
      <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-black">
        <iframe
          class="absolute inset-0 w-full h-full"
          src="https://player.twitch.tv/?channel=makerdeck&parent=makerdeck.net"
          allowfullscreen
          title="MakerDeck Twitch Stream"
          frameborder="0"
        ></iframe>
      </div>
    </div>
  </div>
</section>
