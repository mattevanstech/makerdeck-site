---
// Static hero section
---

<section class="hero-section">
  <div class="hero-content">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/20 text-red-300 text-sm font-semibold mb-6 tracking-wide uppercase">
      <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
      Live 24/7
    </div>

    <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-2 tracking-tight">
      MakerDeck <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Live</span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-400 font-medium mb-6">The Global Maker Community</p>

    <div class="max-w-2xl mx-auto mb-10">
      <p class="text-gray-300 leading-relaxed text-lg">
        We stream 24/7. Tune in anytime to see what the community is building. Join our <strong>monthly meetups</strong>—open to makers & 3D printing enthusiasts of all age, skill, and interest levels.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://twitch.tv/MakerDeck"
        target="_blank"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full bg-purple-600 hover:bg-purple-500 text-white font-bold py-3 px-8 text-lg shadow-xl shadow-purple-900/30 transition transform hover:-translate-y-1"
      >
        <i class="fab fa-twitch"></i> Watch Live
      </a>
      <a
        href="https://discord.gg/makerdeck-226044842126344194"
        target="_blank"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-8 text-lg shadow-xl shadow-indigo-900/30 transition transform hover:-translate-y-1"
      >
        <i class="fa-brands fa-discord"></i> Join Discord
      </a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background-image: url('/img/makerdeck-header.jpeg');
    background-size: cover;
    background-position: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(13,17,23,0.8) 0%, rgba(13,17,23,0.98) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 1.5rem;
    max-width: 900px;
  }
</style>
