---
import type { MakerApp } from '../lib/notion';

interface Props {
  apps: MakerApp[];
}

const { apps } = Astro.props;
---

<section id="maker-apps" class="py-16 bg-[#0d1117] border-t border-gray-800">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Use Our Free Maker Apps</h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">More to come (and we're taking requests)!</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {apps.map((app) => (
        <article
          class="app-card bg-[#161b22] rounded-xl border border-white/5 flex flex-col overflow-hidden transition-all duration-300 cubic-bezier-card"
          data-color={app.color}
        >
          <a href={app.url} target="_blank" rel="noopener noreferrer" class="block flex-grow flex flex-col p-8 no-underline">
            <div class="mb-6 flex items-center justify-between">
              <div class={`h-14 w-14 rounded-2xl bg-gradient-to-br ${app.gradient} flex items-center justify-center border border-white/10`}>
                <i class={`${app.icon} text-2xl`} style={`color: ${app.color}`}></i>
              </div>
              <div class="text-xs font-bold uppercase tracking-widest text-gray-600">Web App</div>
            </div>

            <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">{app.name}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-6 flex-grow">{app.description}</p>

            <div class="mt-auto flex items-center gap-2 font-bold text-sm" style={`color: ${app.color}`}>
              Try it out <i class="fa-solid fa-arrow-right text-xs"></i>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cubic-bezier-card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .app-card:hover {
    transform: translateY(-4px);
  }
</style>

<script>
  // Apply dynamic border glow based on each card's brand color
  document.querySelectorAll<HTMLElement>('.app-card').forEach((card) => {
    const color = card.dataset.color ?? '#ffffff';
    card.addEventListener('mouseover', () => {
      card.style.borderColor = color;
      card.style.boxShadow = `0 10px 30px -10px ${color}44`;
    });
    card.addEventListener('mouseout', () => {
      card.style.borderColor = 'rgba(255,255,255,0.05)';
      card.style.boxShadow = 'none';
    });
  });
</script>
