---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getShowAndTellSubmissions } from '../lib/notion';
import type { ShowAndTellSubmission } from '../lib/notion';

Astro.response.headers.set('Cache-Control', 's-maxage=30, stale-while-revalidate=120');

const submissions = await getShowAndTellSubmissions();

function formatDate(iso: string): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout
  title="Show & Tell — MakerDeck Community Gallery"
  description="See what the MakerDeck community is building and printing. Share your own prints!"
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-[#0d1117] border-b border-gray-800 py-16 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-300 text-sm font-semibold mb-6 tracking-wide uppercase">
        <i class="fa-solid fa-camera text-xs"></i> Community Gallery
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-4 tracking-tight">
        Show & <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Tell</span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl mb-8 max-w-2xl mx-auto">
        See what the MakerDeck community is printing. Share your own builds, find the models, and get inspired.
      </p>
      <button
        id="open-modal-btn"
        class="inline-flex items-center gap-2 rounded-full bg-purple-600 hover:bg-purple-500 text-white font-bold py-3 px-8 text-lg shadow-xl shadow-purple-900/30 transition transform hover:-translate-y-1"
      >
        <i class="fa-solid fa-upload"></i> Submit Your Print
      </button>
    </div>
  </section>

  <!-- Search bar (only shown when there are submissions) -->
  {submissions.length > 0 && (
    <section class="bg-[#0d1117] px-6 pt-10 pb-2">
      <div class="container mx-auto max-w-7xl">
        <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
          <!-- Search input -->
          <div class="relative flex-1">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm pointer-events-none"></i>
            <input
              type="text"
              id="gallery-search"
              placeholder="Search by title or username…"
              autocomplete="off"
              class="w-full bg-[#161b22] border border-gray-700 rounded-xl pl-10 pr-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 transition text-sm"
            />
          </div>
          <!-- Source filter pills -->
          <div class="flex gap-2 shrink-0">
            <button data-filter="all"     class="filter-btn active-filter px-4 py-2 rounded-xl text-sm font-semibold transition">All</button>
            <button data-filter="Web"     class="filter-btn px-4 py-2 rounded-xl text-sm font-semibold transition">
              <i class="fa-solid fa-globe mr-1"></i>Web
            </button>
            <button data-filter="Discord" class="filter-btn px-4 py-2 rounded-xl text-sm font-semibold transition">
              <i class="fa-brands fa-discord mr-1"></i>Discord
            </button>
          </div>
        </div>
        <!-- Result count -->
        <p id="result-count" class="text-gray-600 text-xs mt-3"></p>
      </div>
    </section>
  )}

  <!-- Gallery -->
  <section class="py-10 px-6 bg-[#0d1117]">
    <div class="container mx-auto max-w-7xl">

      {submissions.length === 0 ? (
        <div class="text-center py-24">
          <div class="text-6xl mb-6">🖨️</div>
          <h2 class="text-2xl font-bold text-white mb-3">No prints yet!</h2>
          <p class="text-gray-400 mb-8">Be the first to share what you've been building.</p>
          <button id="open-modal-btn-empty" class="text-purple-400 hover:text-purple-300 font-semibold">
            Submit the first print <i class="fa-solid fa-arrow-right ml-1"></i>
          </button>
        </div>
      ) : (
        <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {submissions.map((s: ShowAndTellSubmission) => (
            <article
              class="gallery-card bg-[#161b22] rounded-xl border border-white/5 overflow-hidden hover:border-purple-500/40 transition-all duration-300 hover:-translate-y-1 flex flex-col group"
              data-name={s.name.toLowerCase()}
              data-submitter={s.submitter.toLowerCase()}
              data-source={s.source === 'Discord' ? 'Discord' : 'Web'}
            >
              <!-- Photo -->
              <div class="relative aspect-square overflow-hidden bg-gray-900">
                <img
                  src={s.photoUrl}
                  alt={s.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute top-3 right-3">
                  <span class={`text-xs font-bold px-2 py-1 rounded-full ${s.source === 'Discord' ? 'bg-indigo-600 text-white' : 'bg-purple-600 text-white'}`}>
                    {s.source === 'Discord' ? <span><i class="fa-brands fa-discord mr-1"></i>Discord</span> : <span><i class="fa-solid fa-globe mr-1"></i>Web</span>}
                  </span>
                </div>
              </div>

              <!-- Info -->
              <div class="p-5 flex flex-col flex-grow">
                <h3 class="text-white font-bold text-lg mb-1 line-clamp-1">{s.name}</h3>
                {s.description && (
                  <p class="text-gray-400 text-sm mb-3 line-clamp-2 flex-grow">{s.description}</p>
                )}
                <div class="mt-auto pt-3 border-t border-white/5 flex items-center justify-between gap-2">
                  <span class="text-gray-500 text-xs flex items-center gap-1">
                    <i class="fa-solid fa-user text-gray-600"></i> {s.submitter}
                  </span>
                  {s.modelSource && (
                    <a
                      href={s.modelSource}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-purple-400 hover:text-purple-300 text-xs font-semibold flex items-center gap-1 shrink-0"
                    >
                      Get Model <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
                    </a>
                  )}
                </div>
                {s.submitted && (
                  <p class="text-gray-600 text-xs mt-2">{formatDate(s.submitted)}</p>
                )}
              </div>
            </article>
          ))}
        </div>
      )}

      <!-- No search results state (hidden by default, shown by JS) -->
      <div id="no-results" class="hidden text-center py-20">
        <div class="text-5xl mb-4">🔍</div>
        <h3 class="text-xl font-bold text-white mb-2">No prints found</h3>
        <p class="text-gray-400 text-sm">Try a different search term or filter.</p>
      </div>
    </div>
  </section>

  <Footer />

<!-- ── Submit Modal ───────────────────────────────────────────────────────── -->
  <div
    id="modal-overlay"
    class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
    aria-modal="true"
    role="dialog"
  >
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/75 backdrop-blur-sm"></div>

    <!-- Card -->
    <div class="relative z-10 bg-[#161b22] border border-white/10 rounded-2xl w-full max-w-xl shadow-2xl flex flex-col max-h-[90vh]">

      <!-- Modal header -->
      <div class="flex items-start justify-between px-6 pt-6 pb-4 border-b border-white/5 shrink-0">
        <div>
          <h2 class="text-xl font-bold text-white">Share Your Print</h2>
          <p class="text-gray-400 text-sm mt-1">All submissions are reviewed before going live.</p>
        </div>
        <button
          id="close-modal-btn"
          class="ml-4 shrink-0 text-gray-500 hover:text-white transition rounded-lg p-1 hover:bg-white/5"
          aria-label="Close"
        >
          <i class="fa-solid fa-xmark text-xl"></i>
        </button>
      </div>

      <!-- Scrollable form area -->
      <div class="overflow-y-auto">
        <form id="submit-form" class="p-6 space-y-5">

          <!-- Photo upload -->
          <div>
            <label class="block text-sm font-semibold text-gray-300 mb-2">
              Photo <span class="text-red-400">*</span>
            </label>
            <div
              id="drop-zone"
              class="border-2 border-dashed border-gray-700 rounded-xl p-6 text-center cursor-pointer hover:border-purple-500/50 transition-colors"
            >
              <img id="photo-preview" class="hidden mx-auto max-h-40 rounded-lg mb-3 object-contain" alt="Preview" />
              <div id="drop-zone-text">
                <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-600 mb-2 block"></i>
                <p class="text-gray-400 font-medium text-sm">Drop your photo here or <span class="text-purple-400">browse</span></p>
                <p class="text-gray-600 text-xs mt-1">JPG, PNG, WEBP — auto-compressed on upload</p>
              </div>
              <input type="file" id="photo-input" name="photo" accept="image/*" class="hidden" />
            </div>
          </div>

          <!-- Print Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-300 mb-2">
              Print Name <span class="text-red-400">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="e.g. Benchy torture test"
              class="w-full bg-[#0d1117] border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 transition"
            />
          </div>

          <!-- Description -->
          <div>
            <label for="description" class="block text-sm font-semibold text-gray-300 mb-2">Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
              placeholder="Tell us about it — filament, settings, anything interesting…"
              class="w-full bg-[#0d1117] border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 transition resize-none"
            ></textarea>
          </div>

          <!-- Model Source -->
          <div>
            <label for="modelSource" class="block text-sm font-semibold text-gray-300 mb-2">Model Source URL</label>
            <input
              type="url"
              id="modelSource"
              name="modelSource"
              placeholder="https://www.printables.com/model/…"
              class="w-full bg-[#0d1117] border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 transition"
            />
          </div>

          <!-- Submitter -->
          <div>
            <label for="submitter" class="block text-sm font-semibold text-gray-300 mb-2">
              Your Name / Discord Handle <span class="text-red-400">*</span>
            </label>
            <input
              type="text"
              id="submitter"
              name="submitter"
              placeholder="e.g. @YourDiscordName"
              class="w-full bg-[#0d1117] border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 transition"
            />
          </div>

          <!-- Submit button -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-purple-600 hover:bg-purple-500 disabled:bg-gray-700 disabled:cursor-not-allowed text-white font-bold py-3 rounded-xl text-base transition flex items-center justify-center gap-2"
          >
            <i class="fa-solid fa-paper-plane"></i>
            <span id="submit-btn-text">Submit Print</span>
          </button>

          <!-- Status messages -->
          <div id="form-success" class="hidden bg-green-500/10 border border-green-500/30 text-green-300 rounded-xl p-4 text-center">
            <i class="fa-solid fa-circle-check text-2xl mb-2 block"></i>
            <p class="font-semibold">Submitted! We'll review it shortly.</p>
            <p class="text-sm text-green-400 mt-1">Once approved it will appear in the gallery and in Discord.</p>
          </div>
          <div id="form-error" class="hidden bg-red-500/10 border border-red-500/30 text-red-300 rounded-xl p-4 text-center">
            <i class="fa-solid fa-circle-exclamation text-xl mb-2 block"></i>
            <p class="font-semibold">Something went wrong. Please try again.</p>
          </div>

        </form>
      </div>
    </div>
  </div>

</Layout>

<script>
  // ── Gallery search & filter ───────────────────────────────────────────────────
  const searchInput  = document.getElementById('gallery-search') as HTMLInputElement | null;
  const filterBtns   = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards        = document.querySelectorAll<HTMLElement>('.gallery-card');
  const noResults    = document.getElementById('no-results')!;
  const resultCount  = document.getElementById('result-count');

  let activeSource = 'all';
  let searchQuery  = '';

  // Style helpers
  function setFilterStyles() {
    filterBtns.forEach(btn => {
      const isActive = btn.dataset.filter === activeSource;
      btn.className = isActive
        ? 'filter-btn px-4 py-2 rounded-xl text-sm font-semibold transition bg-purple-600 text-white'
        : 'filter-btn px-4 py-2 rounded-xl text-sm font-semibold transition bg-[#161b22] text-gray-400 border border-gray-700 hover:border-purple-500/50 hover:text-white';
    });
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const matchesSearch =
        !searchQuery ||
        card.dataset.name!.includes(searchQuery) ||
        card.dataset.submitter!.includes(searchQuery) ||
        card.dataset.source!.toLowerCase().includes(searchQuery);
      const matchesSource =
        activeSource === 'all' || card.dataset.source === activeSource;

      const show = matchesSearch && matchesSource;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Show/hide "no results" message
    noResults?.classList.toggle('hidden', visible > 0);

    // Update result count label
    if (resultCount) {
      resultCount.textContent = searchQuery || activeSource !== 'all'
        ? `${visible} print${visible !== 1 ? 's' : ''} found`
        : '';
    }
  }

  // Initial style pass
  setFilterStyles();

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    applyFilters();
  });

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeSource = btn.dataset.filter!;
      setFilterStyles();
      applyFilters();
    });
  });

  // ── Modal open / close ────────────────────────────────────────────────────────
  const overlay  = document.getElementById('modal-overlay')!;
  const backdrop = document.getElementById('modal-backdrop')!;

  function openModal() {
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    // Reset form state each time modal opens
    document.getElementById('form-success')!.classList.add('hidden');
    document.getElementById('form-error')!.classList.add('hidden');
  }

  function closeModal() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('open-modal-btn')?.addEventListener('click', openModal);
  document.getElementById('open-modal-btn-empty')?.addEventListener('click', openModal);
  document.getElementById('close-modal-btn')?.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── Photo drop zone ──────────────────────────────────────────────────────────
  const dropZone  = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('photo-input') as HTMLInputElement;
  const preview   = document.getElementById('photo-preview') as HTMLImageElement;
  const dropText  = document.getElementById('drop-zone-text')!;

  dropZone.addEventListener('click', () => fileInput.click());

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-purple-500');
  });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-purple-500'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-purple-500');
    const file = e.dataTransfer?.files[0];
    if (file) showPreview(file);
  });
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) showPreview(file);
  });

  // ── Image compression ────────────────────────────────────────────────────────
  function compressImage(file: File): Promise<File> {
    return new Promise((resolve) => {
      const img = new Image();
      const url = URL.createObjectURL(file);
      img.onload = () => {
        const MAX = 2000;
        let { width, height } = img;
        if (width > MAX || height > MAX) {
          if (width > height) {
            height = Math.round(height * MAX / width);
            width  = MAX;
          } else {
            width  = Math.round(width * MAX / height);
            height = MAX;
          }
        }
        const canvas = document.createElement('canvas');
        canvas.width  = width;
        canvas.height = height;
        canvas.getContext('2d')!.drawImage(img, 0, 0, width, height);
        URL.revokeObjectURL(url);
        canvas.toBlob((blob) => {
          const compressed = new File(
            [blob!],
            file.name.replace(/\.[^.]+$/, '.jpg'),
            { type: 'image/jpeg', lastModified: Date.now() }
          );
          resolve(compressed);
        }, 'image/jpeg', 0.85);
      };
      img.src = url;
    });
  }

  async function showPreview(file: File) {
    const compressed = await compressImage(file);
    const reader = new FileReader();
    reader.onload = (e) => {
      preview.src = e.target?.result as string;
      preview.classList.remove('hidden');
      dropText.classList.add('hidden');
    };
    reader.readAsDataURL(compressed);
    const dt = new DataTransfer();
    dt.items.add(compressed);
    fileInput.files = dt.files;
  }

  // ── Form submission ──────────────────────────────────────────────────────────
  const form     = document.getElementById('submit-form') as HTMLFormElement;
  const btn      = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText  = document.getElementById('submit-btn-text')!;
  const success  = document.getElementById('form-success')!;
  const errorBox = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btnText.textContent = 'Uploading…';
    success.classList.add('hidden');
    errorBox.classList.add('hidden');

    try {
      const file = fileInput.files?.[0];
      if (!file) throw new Error('No photo selected');

      // Encode compressed photo as base64 — Vercel blocks multipart/form-data POSTs
      const base64 = await new Promise<string>((resolve, reject) => {
        const reader = new FileReader();
        reader.onload  = () => resolve((reader.result as string).split(',')[1]);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });

      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name:        (document.getElementById('name')        as HTMLInputElement).value.trim(),
          description: (document.getElementById('description') as HTMLTextAreaElement).value.trim(),
          modelSource: (document.getElementById('modelSource') as HTMLInputElement).value.trim(),
          submitter:   (document.getElementById('submitter')   as HTMLInputElement).value.trim(),
          fileName:    file.name,
          fileType:    file.type || 'image/jpeg',
          fileData:    base64,
        }),
      });

      if (!res.ok) throw new Error('Failed');

      // Show success, reset form, auto-close after 2.5s
      success.classList.remove('hidden');
      form.reset();
      preview.classList.add('hidden');
      dropText.classList.remove('hidden');
      setTimeout(() => closeModal(), 2500);

    } catch {
      errorBox.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btnText.textContent = 'Submit Print';
    }
  });
</script>
