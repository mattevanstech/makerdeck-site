---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

function getNextThirdMonday(): Date {
  const now = new Date();

  function thirdMonday(year: number, month: number): Date {
    const d = new Date(year, month, 1);
    const dayOfWeek = d.getDay(); // 0=Sun, 1=Mon
    const daysUntilMonday = dayOfWeek === 1 ? 0 : (8 - dayOfWeek) % 7;
    const firstMonday = 1 + daysUntilMonday;
    return new Date(Date.UTC(year, month, firstMonday + 14, 12, 0, 0));
  }

  const tm = thirdMonday(now.getFullYear(), now.getMonth());
  const eventEnd = new Date(Date.UTC(tm.getUTCFullYear(), tm.getUTCMonth(), tm.getUTCDate(), 20, 0, 0));

  if (now > eventEnd) {
    const nm = now.getMonth() === 11 ? 0 : now.getMonth() + 1;
    const ny = now.getMonth() === 11 ? now.getFullYear() + 1 : now.getFullYear();
    return thirdMonday(ny, nm);
  }
  return tm;
}

const nextEvent = getNextThirdMonday();
const eventDateLong = nextEvent.toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  timeZone: 'America/Los_Angeles',
});
const eventMonth = nextEvent.toLocaleDateString('en-US', { month: 'short', timeZone: 'America/Los_Angeles' });
const eventDay = nextEvent.toLocaleDateString('en-US', { day: 'numeric', timeZone: 'America/Los_Angeles' });
